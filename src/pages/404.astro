---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { getLocaleFromUrl, useTranslations } from '../utils/i18n';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<BaseLayout title={t('seo.pageNotFound')} description={t('seo.pageNotFoundDesc')}>
  <Header slot="header">
    <LanguageSwitcher slot="language-switcher" />
  </Header>

  <main class="not-found">
    <div class="container">
      <h1 class="code">404</h1>
      <h2 class="title">{t('seo.pageNotFound')}</h2>
      <p class="description">{t('seo.pageNotFoundDesc')}</p>
      <a href={locale === 'en' ? '/en/' : '/es/'} class="home-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        {t('nav.home')}
      </a>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .not-found {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - var(--header-height));
    padding: var(--space-2xl) 0;
    text-align: center;
  }

  .code {
    font-family: var(--font-mono);
    font-size: clamp(6rem, 20vw, 12rem);
    font-weight: 700;
    line-height: 1;
    color: var(--color-fg-subtle);
    letter-spacing: -0.05em;
  }

  .title {
    font-size: var(--text-2xl);
    font-weight: 600;
    margin-top: var(--space-lg);
  }

  .description {
    font-size: var(--text-lg);
    color: var(--color-fg-muted);
    margin-top: var(--space-md);
    max-width: 400px;
  }

  .home-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xl);
    padding: var(--space-md) var(--space-lg);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-bg);
    background: var(--color-fg);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .home-link:hover {
    opacity: 0.85;
  }

  .home-link svg {
    flex-shrink: 0;
  }
</style>
