---
import { SEO } from 'astro-seo';
import { getLocaleFromUrl } from '../utils/i18n';
import { SITE } from '../utils/consts';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title = SITE.name,
  description = SITE.description,
  ogImage = '/og-image.svg',
  canonicalUrl = Astro.url.href,
} = Astro.props;

const locale = getLocaleFromUrl(Astro.url);
const fullTitle = title.includes(SITE.name) ? title : `${title} — ${SITE.name}`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Preconnect to external origins for performance -->
    <link rel="preconnect" href="https://github.com" />
    <link rel="preconnect" href="https://linkedin.com" />
    <link rel="dns-prefetch" href="https://github.com" />
    <link rel="dns-prefetch" href="https://linkedin.com" />

    <!-- Preload OG image for better LCP -->
    <link rel="preload" as="image" href={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.svg" />
    <meta name="theme-color" content="#09090b" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />

    <script is:inline>
      (function() {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = saved || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>

    <SEO
      title={fullTitle}
      description={description}
      canonical={canonicalUrl}
      openGraph={{
        basic: {
          title: fullTitle,
          type: 'profile',
          image: ogImage,
          url: canonicalUrl,
        },
        optional: {
          locale: locale === 'en' ? 'en_US' : 'es_ES',
          siteName: SITE.name,
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title: fullTitle,
        description: description,
        image: ogImage,
        imageAlt: SITE.name,
      }}
    />

    <!-- hreflang for i18n -->
    <link rel="alternate" hreflang="en" href={`${SITE.domain}/en/`} />
    <link rel="alternate" hreflang="es" href={`${SITE.domain}/es/`} />
    <link rel="alternate" hreflang="x-default" href={`${SITE.domain}/`} />

    <!-- SEO: Keywords -->
    <meta name="keywords" content="Software Developer, Web Developer, Mobile Developer, Frontend, Backend, JavaScript, TypeScript, React, Astro, Node.js, Colombia" />

    <!-- Schema.org JSON-LD: Person + BreadcrumbList -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": SITE.name,
      "jobTitle": SITE.title,
      "description": SITE.description,
      "email": SITE.email,
      "url": `https://${SITE.domain}`,
      "image": `/og-image.svg`,
      "sameAs": [
        SITE.github,
        SITE.linkedin
      ],
      "knowsAbout": ["Software Development", "Web Applications", "Mobile Applications"],
      "inLanguage": locale === 'en' ? "en-US" : "es-ES",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": canonicalUrl
      }
    })} />

    <!-- BreadcrumbList Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": locale === 'en' ? "Home" : "Inicio",
          "item": `https://${SITE.domain}`
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": locale === 'en' ? "Resume" : "Currículum",
          "item": canonicalUrl
        }
      ]
    })} />

    <script is:inline>
      // Intersection Observer for scroll animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target;
              // Apply stagger delay if data-stagger is set
              const stagger = el.dataset.stagger;
              if (stagger) {
                el.style.setProperty('--stagger-delay', stagger + 'ms');
              }
              el.classList.add('is-visible');
              observer.unobserve(el);
            }
          });
        },
        { threshold: 0.1 }
      );

      document.addEventListener('DOMContentLoaded', () => {
        const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
        if (!mq.matches) {
          document.querySelectorAll('[data-animate]').forEach((el) => {
            observer.observe(el);
          });
        } else {
          document.querySelectorAll('[data-animate]').forEach((el) => {
            el.classList.add('is-visible');
          });
        }
      });
    </script>

    <script is:inline>
      // Mobile menu toggle
      document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.getElementById('mobile-menu-toggle');
        const nav = document.getElementById('mobile-nav');
        if (toggle && nav) {
          toggle.addEventListener('click', () => {
            nav.classList.toggle('is-open');
            toggle.setAttribute('aria-expanded', nav.classList.contains('is-open').toString());
          });
        }
      });
    </script>

  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot name="header" />
    <slot />
  </body>
</html>
