---
import { getLocaleFromUrl, useTranslations } from '../utils/i18n';
import { SITE } from '../utils/consts';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<section id="contact" class="contact-section" data-animate>
  <div class="container">
    <h2 class="section-title">{t('section.contact')}</h2>

    <div class="contact-grid">
      <form id="contact-form" class="contact-form card">
        <div class="form-group">
          <label for="name" class="form-label">
            {locale === 'en' ? 'Name' : 'Nombre'}
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            class="form-input"
            placeholder={locale === 'en' ? 'Your name' : 'Tu nombre'}
          />
        </div>

        <div class="form-group">
          <label for="email" class="form-label">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="form-input"
            placeholder="email@example.com"
          />
        </div>

        <div class="form-group">
          <label for="message" class="form-label">
            {locale === 'en' ? 'Message' : 'Mensaje'}
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="form-input form-textarea"
            placeholder={locale === 'en' ? 'Your message...' : 'Tu mensaje...'}
          ></textarea>
        </div>

        <button type="submit" class="submit-btn">
          <span class="btn-text">
            {locale === 'en' ? 'Send Message' : 'Enviar Mensaje'}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </span>
          <span class="btn-loading">
            <svg class="spinner" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" stroke-dasharray="60 30"/>
            </svg>
          </span>
        </button>

        <p id="form-status" class="form-status"></p>
      </form>

      <div class="contact-info">
        <div class="contact-intro">
          <p>
            {locale === 'en'
              ? "I'm always open to discussing new opportunities, interesting projects, or just having a chat about technology."
              : "Siempre estoy abierto a discutir nuevas oportunidades, proyectos interesantes, o simplemente charlar sobre tecnología."}
          </p>
        </div>

        <div class="contact-links">
          <a href={`mailto:${SITE.email}`} class="contact-link">
            <span class="link-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </span>
            <span class="link-text">{SITE.email}</span>
          </a>

          <a href={SITE.github} target="_blank" rel="noopener noreferrer" class="contact-link">
            <span class="link-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
              </svg>
            </span>
            <span class="link-text">GitHub</span>
          </a>

          <a href={SITE.linkedin} target="_blank" rel="noopener noreferrer" class="contact-link">
            <span class="link-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </span>
            <span class="link-text">LinkedIn</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusEl = document.getElementById('form-status') as HTMLParagraphElement;
  const submitBtn = form?.querySelector('.submit-btn') as HTMLButtonElement;
  const btnText = submitBtn?.querySelector('.btn-text') as HTMLSpanElement;
  const btnLoading = submitBtn?.querySelector('.btn-loading') as HTMLSpanElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const data = {
      name: formData.get('name') as string,
      email: formData.get('email') as string,
      message: formData.get('message') as string,
    };

    // Show loading state
    if (btnText && btnLoading && submitBtn) {
      btnText.style.display = 'none';
      btnLoading.style.display = 'inline-flex';
      submitBtn.disabled = true;
    }

    try {
      // TODO: Replace with your deployed Worker URL
      const WORKER_URL = 'https://contact-form.darellorlandoe.workers.dev';

      const response = await fetch(WORKER_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        statusEl!.textContent = locale === 'es'
          ? '¡Mensaje enviado! Te contactaré pronto.'
          : 'Message sent! I\'ll get back to you soon.';
        statusEl!.className = 'form-status success';
        form.reset();
      } else {
        throw new Error('Failed to send');
      }
    } catch (error) {
      statusEl!.textContent = locale === 'es'
        ? 'Error al enviar. Por favor intenta de nuevo.'
        : 'Failed to send. Please try again.';
      statusEl!.className = 'form-status error';
    } finally {
      if (btnText && btnLoading && submitBtn) {
        btnText.style.display = 'inline-flex';
        btnLoading.style.display = 'none';
        submitBtn.disabled = false;
      }
    }
  });
</script>

<style>
  .contact-section {
    padding: var(--space-xl) 0;
    background: var(--color-bg-alt);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .contact-form {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .form-label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-fg);
    letter-spacing: 0.02em;
  }

  .form-input {
    padding: var(--space-sm) var(--space-md);
    font-size: var(--text-base);
    font-family: var(--font-body);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-fg);
    border-radius: 0;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
    outline: none;
  }

  .form-input::placeholder {
    color: var(--color-fg-subtle);
  }

  .form-input:focus {
    border-color: var(--color-fg);
    box-shadow: 0 0 0 1px var(--color-fg);
  }

  .form-textarea {
    resize: vertical;
    min-height: 140px;
  }

  .submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-sm) var(--space-lg);
    font-size: var(--text-sm);
    font-weight: 500;
    font-family: var(--font-body);
    background: var(--color-fg);
    color: var(--color-bg);
    border: 1px solid var(--color-fg);
    cursor: pointer;
    transition:
      background var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
    min-height: 48px;
    align-self: flex-start;
  }

  .submit-btn:hover:not(:disabled) {
    background: var(--color-bg);
    color: var(--color-fg);
  }

  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-text {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .btn-loading {
    display: none;
    align-items: center;
  }

  .spinner {
    width: 18px;
    height: 18px;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .form-status {
    font-size: var(--text-sm);
    padding: var(--space-sm);
    display: none;
  }

  .form-status.success {
    display: block;
    color: #166534;
    background: #dcfce7;
    border-left: 3px solid #22c55e;
  }

  .form-status.error {
    display: block;
    color: #991b1b;
    background: #fee2e2;
    border-left: 3px solid #ef4444;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    padding-top: var(--space-md);
  }

  .contact-intro p {
    font-size: var(--text-lg);
    line-height: 1.8;
    color: var(--color-fg-muted);
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-md);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-fg);
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .contact-link:hover {
    opacity: 0.6;
  }

  .link-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-info {
      padding-top: 0;
    }

    .submit-btn {
      align-self: stretch;
    }
  }
</style>
