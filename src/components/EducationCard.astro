---
import { getLocaleFromUrl } from '../utils/i18n';

interface Props {
  institution: string;
  degree: string;
  startDate: string;
  endDate?: string;
  description?: string;
}

const locale = getLocaleFromUrl(Astro.url);
const { institution, degree, startDate, endDate, description } = Astro.props;

function formatDate(dateStr: string): string {
  const [year, month] = dateStr.split('-');
  const date = new Date(parseInt(year), parseInt(month) - 1);
  return date.toLocaleDateString(locale === 'es' ? 'es-ES' : 'en-US', { month: 'short', year: 'numeric' });
}

const endDateLabel = locale === 'es' ? 'Presente' : 'Present';
const endDateDisplay = !endDate || endDate === 'present' ? endDateLabel : formatDate(endDate);
---

<article class="education-card card">
  <div class="card-header">
    <div class="card-title-group">
      <h3 class="card-title">{degree}</h3>
      <span class="card-subtitle">{institution}</span>
    </div>
    <time class="card-date">
      {formatDate(startDate)} — {endDateDisplay}
    </time>
  </div>

  {description && <p class="card-description">{description}</p>}
</article>

<style>
  .education-card {
    margin-bottom: var(--space-lg);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    margin-bottom: var(--space-xs);
  }

  .card-subtitle {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
  }

  .card-date {
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    color: var(--color-fg-muted);
    white-space: nowrap;
  }

  .card-description {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--color-fg-muted);
  }

  @media (max-width: 768px) {
    .card-header {
      flex-direction: column;
    }
  }
</style>
